# Port for the HTTP API that exposes send-message endpoints
PORT=3030

# Shared secret required in the `x-api-key` header on every HTTP request.
# Generate one with: openssl rand -hex 32
API_KEY=change-me-please

# Where Baileys persists session credentials. Keep this OUT of git.
AUTH_DIR=./auth_info

# Phone number (with country code, digits only) used to request a pairing code
# instead of a QR. Leave empty to fall back to QR login.
# Example: 5491122334455
PAIRING_NUMBER=

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info

# Optional: comma-separated JIDs allowed to trigger bot commands.
# Empty = allow everyone. Example: 5491122334455@s.whatsapp.net
BOT_ALLOWLIST=
