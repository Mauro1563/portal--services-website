# =============================================================================
# WhatsApp connector (used by /api/contact to forward leads to WhatsApp)
# =============================================================================
# Public URL where the whatsapp/ service is running (no trailing slash).
# Example: https://wa.your-domain.com
WHATSAPP_SERVICE_URL=

# Same API_KEY configured in whatsapp/.env (must match exactly).
WHATSAPP_API_KEY=

# WhatsApp number that receives the lead notifications.
# International format, digits only, NO leading 0, NO "+" sign.
# UK example:    447467232018   (for +44 7467 232018)
# Argentina ex.: 5491122334455  (for +54 9 11 2233-4455)
LEAD_NOTIFY_NUMBER=
