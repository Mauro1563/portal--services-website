# =============================================================================
# WhatsApp connector (used by /api/contact to forward leads to WhatsApp)
# =============================================================================
# Public URL where the whatsapp/ service is running (no trailing slash).
# Example: https://wa.your-domain.com
WHATSAPP_SERVICE_URL=

# Same API_KEY configured in whatsapp/.env (must match exactly).
WHATSAPP_API_KEY=

# WhatsApp number that receives the lead notifications.
# International format, digits only, NO leading 0, NO "+" sign.
# UK example:    447467232018   (for +44 7467 232018)
# Argentina ex.: 5491122334455  (for +54 9 11 2233-4455)
LEAD_NOTIFY_NUMBER=

# =============================================================================
# Notion lead storage (optional — leave empty to skip Notion sync)
# =============================================================================
# 1. Create an internal integration:  https://www.notion.so/my-integrations
#    → "+ New integration" → Type: Internal → copy the secret (starts with `secret_` or `ntn_`)
# 2. Open the "Portal Services — Leads" database in Notion
#    → top-right "..." menu → Connections → Connect to → pick your integration
# 3. Paste the secret here.
NOTION_TOKEN=

# Database ID from the URL: notion.so/<workspace>/<DATABASE_ID>?v=...
# The leads database created for this project is:
NOTION_LEADS_DATABASE_ID=3c64d966dca14c21b546eadc43aaba7b
